rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Default deny
    match /{document=**} {
      allow read, write: if false;
    }

    // Helper functions
    function isSignedIn() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    function isValidId(id) {
      return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$');
    }

    function incoming() {
      return request.resource.data;
    }

    function existing() {
      return resource.data;
    }

    function isVerified() {
      return request.auth.token.email_verified == true;
    }

    // Profiles
    match /profiles/{userId} {
      allow get: if isOwner(userId);
      allow create: if isOwner(userId) && isValidProfile(incoming());
      allow update: if isOwner(userId) && isValidProfile(incoming()) && (
        incoming().diff(existing()).affectedKeys().hasOnly(['full_name', 'phone_number', 'updated_at'])
      );

      function isValidProfile(data) {
        return data.auth_user_id == request.auth.uid 
            && data.email == request.auth.token.email
            && data.created_at is timestamp
            && data.updated_at is timestamp;
      }
    }

    // Homes
    match /homes/{homeId} {
      allow list: if isSignedIn() && resource.data.user_id == request.auth.uid;
      allow get: if isSignedIn() && resource.data.user_id == request.auth.uid;
      allow create: if isSignedIn() && incoming().user_id == request.auth.uid && isValidHome(incoming());
      allow update: if isSignedIn() && existing().user_id == request.auth.uid && isValidHome(incoming()) && (
        incoming().diff(existing()).affectedKeys().hasOnly(['home_name', 'owner_name', 'address_line_1', 'address_line_2', 'city', 'state', 'zip_code', 'country', 'home_type', 'notes', 'updated_at'])
      );
      allow delete: if isSignedIn() && existing().user_id == request.auth.uid;

      function isValidHome(data) {
        return data.user_id == request.auth.uid
            && data.home_name is string && data.home_name.size() > 0 && data.home_name.size() <= 100
            && data.created_at is timestamp
            && data.updated_at is timestamp;
      }

      // Rooms
      match /rooms/{roomId} {
        allow list: if isSignedIn() && resource.data.user_id == request.auth.uid;
        allow get: if isSignedIn() && resource.data.user_id == request.auth.uid;
        allow create: if isSignedIn() && incoming().user_id == request.auth.uid && isValidRoom(incoming());
        allow update: if isSignedIn() && existing().user_id == request.auth.uid && isValidRoom(incoming()) && (
          incoming().diff(existing()).affectedKeys().hasOnly(['room_name', 'room_description', 'room_photo_url', 'notes', 'updated_at'])
        );
        allow delete: if isSignedIn() && existing().user_id == request.auth.uid;

        function isValidRoom(data) {
          return data.user_id == request.auth.uid
              && data.home_id == homeId
              && data.room_name is string && data.room_name.size() > 0 && data.room_name.size() <= 100
              && data.created_at is timestamp
              && data.updated_at is timestamp;
        }
      }
    }

    // Inventory Items
    match /inventory_items/{itemId} {
      allow list: if isSignedIn() && resource.data.user_id == request.auth.uid;
      allow get: if isSignedIn() && resource.data.user_id == request.auth.uid;
      allow create: if isSignedIn() && incoming().user_id == request.auth.uid && isValidItem(incoming());
      allow update: if isSignedIn() && existing().user_id == request.auth.uid && isValidItem(incoming()) && (
        incoming().diff(existing()).affectedKeys().hasOnly([
          'room_id', 'item_name', 'category', 'description', 'brand', 'model_number', 'serial_number', 
          'quantity', 'purchase_date', 'purchase_price', 'store_vendor', 'current_estimated_value', 
          'replacement_value', 'condition', 'insurance_notes', 'warranty_provider', 
          'warranty_start_date', 'warranty_end_date', 'warranty_status', 'notes', 'updated_at'
        ])
      );
      allow delete: if isSignedIn() && existing().user_id == request.auth.uid;

      function isValidItem(data) {
        return data.user_id == request.auth.uid
            && data.item_name is string && data.item_name.size() > 0 && data.item_name.size() <= 100
            && data.created_at is timestamp
            && data.updated_at is timestamp;
      }

      // Photos
      match /photos/{photoId} {
        allow list: if isSignedIn() && resource.data.user_id == request.auth.uid;
        allow get: if isSignedIn() && resource.data.user_id == request.auth.uid;
        allow create: if isSignedIn() && incoming().user_id == request.auth.uid && isValidPhoto(incoming());
        allow delete: if isSignedIn() && existing().user_id == request.auth.uid;

        function isValidPhoto(data) {
          return data.user_id == request.auth.uid
              && data.item_id == itemId
              && data.file_url is string
              && data.created_at is timestamp;
        }
      }

      // Documents
      match /documents/{docId} {
        allow list: if isSignedIn() && resource.data.user_id == request.auth.uid;
        allow get: if isSignedIn() && resource.data.user_id == request.auth.uid;
        allow create: if isSignedIn() && incoming().user_id == request.auth.uid && isValidDoc(incoming());
        allow delete: if isSignedIn() && existing().user_id == request.auth.uid;

        function isValidDoc(data) {
          return data.user_id == request.auth.uid
              && data.item_id == itemId
              && data.file_url is string
              && data.created_at is timestamp;
        }
      }
    }
  }
}
